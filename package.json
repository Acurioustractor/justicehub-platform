{
  "name": "justicehub-platform",
  "version": "1.0.0",
  "description": "Digital platform that transforms how grassroots organizations support young people",
  "main": "dist/server.js",
  "scripts": {
    "dev": "next dev -p 3004",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "npm run type-check:green-lanes",
    "type-check:diagnostic": "npm run type-check:all",
    "type-check:all": "tsc -p tsconfig.typecheck.json --noEmit --pretty false --incremental false",
    "type-check:green-lanes": "npm run type-check:sprint1 && npm run type-check:governed-proof && npm run type-check:alma && npm run type-check:funding && npm run type-check:org-hub && npm run type-check:admin-core && npm run type-check:intelligence && npm run type-check:search-and-chat && npm run type-check:public-site && npm run type-check:content-and-media && npm run type-check:integrations-and-sync && npm run type-check:api-content-supabase-hub && npm run type-check:api-core-supabase-hub && npm run type-check:admin-navigation-hub && npm run type-check:admin-shell && npm run type-check:misc-shell-components && npm run type-check:residual-api-core && npm run type-check:residual-api-content",
    "type-check:sprint1": "tsc -p tsconfig.sprint1.json --noEmit --pretty false --incremental false",
    "type-check:governed-proof": "tsc -p tsconfig.governed-proof.json --noEmit --pretty false --incremental false",
    "type-check:funding": "tsc -p tsconfig.funding.json --noEmit --pretty false --incremental false",
    "type-check:alma": "tsc -p tsconfig.alma.json --noEmit --pretty false --incremental false",
    "type-check:org-hub": "tsc -p tsconfig.org-hub.json --noEmit --pretty false --incremental false",
    "type-check:admin-core": "tsc -p tsconfig.admin-core.json --noEmit --pretty false --incremental false",
    "type-check:intelligence": "tsc -p tsconfig.intelligence.json --noEmit --pretty false --incremental false",
    "type-check:search-and-chat": "tsc -p tsconfig.search-and-chat.json --noEmit --pretty false --incremental false",
    "type-check:public-site": "tsc -p tsconfig.public-site.json --noEmit --pretty false --incremental false",
    "type-check:content-and-media": "tsc -p tsconfig.content-and-media.json --noEmit --pretty false --incremental false",
    "type-check:integrations-and-sync": "tsc -p tsconfig.integrations-and-sync.json --noEmit --pretty false --incremental false",
    "type-check:regenerate-residual-lanes": "node scripts/typecheck/regenerate-residual-lanes.mjs",
    "type-check:regenerate-hub-lanes": "node scripts/typecheck/regenerate-hub-lanes.mjs",
    "type-check:admin-navigation-hub": "tsc -p tsconfig.admin-navigation-hub.json --noEmit --pretty false --incremental false",
    "type-check:api-content-supabase-hub": "tsc -p tsconfig.api-content-supabase-hub.json --noEmit --pretty false --incremental false",
    "type-check:api-core-supabase-hub": "tsc -p tsconfig.api-core-supabase-hub.json --noEmit --pretty false --incremental false",
    "type-check:admin-shell": "tsc -p tsconfig.admin-shell.json --noEmit --pretty false --incremental false",
    "type-check:misc-shell-components": "tsc -p tsconfig.misc-shell-components.json --noEmit --pretty false --incremental false",
    "type-check:residual-api-core": "tsc -p tsconfig.residual-api-core.json --noEmit --pretty false --incremental false",
    "type-check:residual-api-content": "tsc -p tsconfig.residual-api-content.json --noEmit --pretty false --incremental false",
    "type-check:residual-app-shell": "tsc -p tsconfig.residual-app-shell.json --noEmit --pretty false --incremental false",
    "type-check:residual-api-services": "tsc -p tsconfig.residual-api-services.json --noEmit --pretty false --incremental false",
    "types:generate": "npx supabase gen types typescript --linked > src/types/database.types.ts",
    "types:watch": "nodemon --watch supabase/migrations --exec 'npm run types:generate'",
    "screenshots": "node scripts/take-screenshots.js",
    "screenshots:install": "npm install playwright && npx playwright install chromium",
    "scrape": "NODE_OPTIONS='--require dotenv/config' npx tsx src/scripts/scrape-qld-services.ts",
    "scrape:batch": "NODE_OPTIONS='--require dotenv/config' npx tsx src/scripts/scrape-qld-services-batch.ts",
    "scrape:high": "NODE_OPTIONS='--require dotenv/config' npx tsx src/scripts/scrape-qld-services-batch.ts 3 high",
    "scrape:all": "NODE_OPTIONS='--require dotenv/config' npx tsx src/scripts/scrape-qld-services-batch.ts 5 all",
    "scrape:daemon": "NODE_OPTIONS='--require dotenv/config' npx tsx src/scripts/scraper-daemon.ts",
    "scrape:daemon:bg": "nohup npm run scrape:daemon > logs/daemon.log 2>&1 &",
    "audit:runtime-schema": "npx tsx scripts/audit/validate-runtime-schema.ts",
    "check:route-links": "node scripts/audit/check-route-links.mjs",
    "check:frontend-smoke": "node scripts/audit/frontend-smoke-check.mjs",
    "check:funding-smoke": "node scripts/audit/funding-smoke-check.mjs",
    "check:funding-smoke:seeded": "FUNDING_SMOKE_EXPECT_SEEDED=true node scripts/audit/funding-smoke-check.mjs",
    "check:funding-preflight": "node scripts/audit/funding-smoke-preflight.mjs",
    "check:funding:auto": "node scripts/audit/run-funding-local-gate.mjs",
    "check:funding-promotion-smoke": "node scripts/audit/funding-promotion-smoke.mjs",
    "check:funding-public-contribution-smoke": "node scripts/audit/funding-public-contribution-smoke.mjs",
    "check:funding-public-evidence-moderation-smoke": "node scripts/audit/funding-public-evidence-moderation-smoke.mjs",
    "check:funding-application-draft-smoke": "node scripts/audit/funding-application-draft-smoke.mjs",
    "check:funding-admin-auth-smoke": "node scripts/audit/funding-admin-auth-smoke.mjs",
    "check:funding-browser-flow-smoke": "node scripts/audit/funding-browser-flow-smoke.mjs",
    "check:funding-conversation-smoke": "node scripts/audit/funding-conversation-smoke.mjs",
    "check:funding-conversation-admin-triage-smoke": "node scripts/audit/funding-conversation-admin-triage-smoke.mjs",
    "check:funding-relationship-pathway-smoke": "node scripts/audit/funding-relationship-pathway-smoke.mjs",
    "check:funding-regression": "node scripts/audit/funding-regression-suite.mjs",
    "check:funding-regression:seed": "npm run seed:funding-smoke-fixtures && npm run check:funding-regression",
    "check:funding-regression:reset": "npm run clean:funding-smoke-artifacts && npm run seed:funding-smoke-fixtures && npm run check:funding-regression",
    "check:funding": "npm run check:funding-regression:reset",
    "clean:funding-smoke-artifacts": "node scripts/audit/cleanup-funding-smoke-artifacts.mjs",
    "seed:admin-browser-smoke-user": "node scripts/audit/ensure-admin-browser-smoke-user.mjs",
    "seed:funding-smoke-fixtures": "node scripts/audit/seed-funding-smoke-fixtures.mjs",
    "check:no-hardcoded-supabase-keys": "bash scripts/check-no-hardcoded-supabase-keys.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
