#!/bin/bash
# Dependency-free secret guard — blocks commits that introduce hardcoded
# JWTs / API secret keys. Activated via: git config core.hooksPath .githooks
# (run scripts/setup-hooks.sh once per clone). CI uses gitleaks (.gitleaks.toml).
#
# False positive? re-run with:  ALLOW_SECRET=1 git commit ...
set -u
[ "${ALLOW_SECRET:-}" = "1" ] && exit 0

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

# Full 3-part JWT literal, Supabase secret keys, OpenAI-style keys.
PATTERN='eyJ[A-Za-z0-9_-]{15,}\.eyJ[A-Za-z0-9_-]{15,}\.[A-Za-z0-9_-]{10,}|sb_secret_[A-Za-z0-9]{20,}|sk-[A-Za-z0-9]{20,}'

hits=0
for f in $staged; do
  [ -f "$f" ] || continue
  case "$f" in
    *.lock|*.png|*.jpg|*.jpeg|*.gif|*.pdf|*.ico|*.woff*|package-lock.json|*.snap) continue;;
  esac
  if grep -nIE "$PATTERN" "$f" >/dev/null 2>&1; then
    echo "BLOCKED: possible hardcoded secret in $f"
    grep -nIE "$PATTERN" "$f" | sed -E 's/(eyJ|sb_secret_|sk-)[A-Za-z0-9_.-]*/<secret-redacted>/g' | head -3
    hits=1
  fi
done

if [ "$hits" = "1" ]; then
  echo ""
  echo "Commit blocked by .githooks/pre-commit. Move secrets to env (.env.local, Vercel)."
  echo "False positive? re-run with: ALLOW_SECRET=1 git commit ..."
  exit 1
fi
exit 0
