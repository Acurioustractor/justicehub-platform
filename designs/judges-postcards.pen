              "textGrowth": "fixed-width",
              "width": 736,
              "content": "WHAT TO LISTEN FOR",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "NY44f",
              "x": 28,
              "y": 66,
              "fill": "#F5F0E8",
              "textGrowth": "fixed-width",
              "width": 736,
              "content": "Family, programs, and practical support are what he named. This is what judges should be listening for on the trip.",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 30,
              "fontWeight": "600"
