          "content": "“He trusts us.\nWe earned that trust.”",
          "lineHeight": 0.94,
          "fontFamily": "Playfair Display",
          "fontSize": 92,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "HdOpg",
          "x": 56,
          "y": 790,
          "name": "subX",
          "fill": "#FFFFFFCC",
          "textGrowth": "fixed-width",
          "width": 900,
          "content": "Other services distanced from him when it got hard. Oonchiumpa did not. Xavier now leads Stretch Bed building work.",
          "lineHeight": 1.2,
          "fontFamily": "Inter",
          "fontSize": 28,
          "fontWeight": "500"
        },
