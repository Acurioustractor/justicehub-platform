            }
          ]
        },
        {
          "type": "text",
          "id": "c1CBW",
          "x": 56,
          "y": 150,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 820,
          "content": "Nigel named what detention interrupts",
          "lineHeight": 0.96,
          "fontFamily": "Playfair Display",
          "fontSize": 74,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "onwtT",
          "x": 56,
          "y": 332,
          "fill": "#4F463F",
          "textGrowth": "fixed-width",
          "width": 792,
          "content": "Nigel, 14, likes school and wants to be a footy player. He knows he needs to go to school every day to get there. What he described as harmful was not just custody itself, but being taken away from family and home.",
          "lineHeight": 1.22,
          "fontFamily": "Inter",
          "fontSize": 34,
          "fontWeight": "500"
        },
        {
          "type": "frame",
          "id": "VZ5rP",
          "x": 56,
          "y": 660,
          "width": 792,
          "height": 208,
          "fill": "#FFFFFF",
          "cornerRadius": 28,
          "stroke": {
            "thickness": 2,
            "fill": "#C8DDD3"
          },
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "JZWo4",
              "x": 28,
              "y": 24,
              "fill": "#1E5E4B",
              "textGrowth": "fixed-width",
              "width": 736,
              "content": "WHAT YOUTH JUSTICE SHOULD PROTECT",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "R53wn",
              "x": 28,
              "y": 64,
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": 736,
              "content": "Family, school, movement, and a consistent adult are already visible here. Oonchiumpa consistency is the intervention.",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 30,
              "fontWeight": "600"
            }
          ]
        },
        {
          "type": "text",
          "id": "tsAUM",
          "x": 56,
          "y": 900,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 792,
          "content": "Use this card when the conversation needs to come back to family, schooling, and what support actually looks like in practice.",
