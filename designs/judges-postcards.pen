    {
      "type": "frame",
      "id": "fJVIQ",
      "x": 4800,
      "y": 1300,
      "name": "Postcard 02 / Jackquann + Nigel Back",
      "width": 1480,
      "height": 1050,
      "fill": "#F5F0E8",
      "cornerRadius": 44,
      "stroke": {
        "thickness": 2,
        "fill": "#D8CCBD"
      },
      "layout": "none",
      "children": [
        {
          "type": "frame",
          "id": "FNR6G",
          "x": 82,
          "y": 56,
          "width": 790,
          "height": 938,
          "fill": "#FBF7F0",
