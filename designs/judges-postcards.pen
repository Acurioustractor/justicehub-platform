    {
      "type": "frame",
      "id": "Tudlx",
      "x": 4800,
      "y": 3620,
      "name": "Postcard 06 / Trust Back",
      "width": 1480,
      "height": 1050,
      "fill": "#F5F0E8",
      "cornerRadius": 44,
      "stroke": {
        "thickness": 2,
        "fill": "#D8CCBD"
      },
      "layout": "none",
      "children": [
        {
          "type": "frame",
          "id": "zGszo",
          "x": 82,
          "y": 56,
          "width": 790,
          "height": 938,
          "fill": "#FBF7F0",
          "cornerRadius": 28,
          "stroke": {
