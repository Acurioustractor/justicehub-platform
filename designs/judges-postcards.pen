              },
              {
                "color": "#000000F5",
                "position": 1
              }
            ]
          },
          "width": 1480,
          "height": 1050
        },
        {
          "type": "text",
          "id": "zDERp",
          "x": 140,
          "y": 642,
          "name": "mainF",
          "fill": "#FFFFFF",
          "textGrowth": "fixed-width",
