          "fill": "#111111",
          "cornerRadius": 999,
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "GTdnC",
              "x": 22,
              "y": 18,
              "fill": "#F5F0E8",
              "textGrowth": "fixed-width",
              "width": 176,
              "content": "CARD 04 / NIGEL",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 18,
              "fontWeight": "700"
            }
          ]
        },
        {
          "type": "text",
          "id": "c1CBW",
          "x": 96,
          "y": 150,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 740,
          "content": "Nigel named what detention interrupts",
          "lineHeight": 0.96,
          "fontFamily": "Playfair Display",
          "fontSize": 68,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "onwtT",
          "x": 96,
          "y": 332,
          "fill": "#4F463F",
          "textGrowth": "fixed-width",
          "width": 710,
          "content": "Nigel lives at a station in Double Camp. He is 14. He likes school and wants to be a footy player. He has been to Don Dale in Darwin. He described it as kids fighting every day.\n\nAsked what it feels like being away, he said \"Bad. Like, going away from my family and stuff.\" In court, talking to the judge, he says he panics. Oonchiumpa picks him up, takes him to school, and gives him consistency. That consistency is the intervention.",
          "lineHeight": 1.26,
          "fontFamily": "Inter",
          "fontSize": 24,
          "fontWeight": "500"
        },
        {
          "type": "frame",
          "id": "VZ5rP",
          "x": 96,
          "y": 700,
          "width": 710,
          "height": 208,
          "fill": "#FFFFFF",
          "cornerRadius": 28,
          "stroke": {
            "thickness": 2,
            "fill": "#C8DDD3"
          },
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "JZWo4",
              "x": 28,
              "y": 24,
              "fill": "#1E5E4B",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "WHAT JUDGES SHOULD HEAR",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "R53wn",
              "x": 28,
              "y": 64,
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "\"I wanna be a footy player.\" \"Go to school every day.\" He already knows what he needs. The system keeps interrupting it.",
              "lineHeight": 1.24,
              "fontFamily": "Inter",
              "fontSize": 24,
              "fontWeight": "600"
            }
          ]
        },
        {
          "type": "text",
          "id": "tsAUM",
          "x": 96,
          "y": 920,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 710,
          "content": "Use this card when the conversation needs to come back to family, schooling, and what support actually looks like in practice.",
          "lineHeight": 1.2,
          "fontFamily": "Inter",
          "fontSize": 22,
          "fontWeight": "600"
        },
        {
          "type": "frame",
          "id": "KOqMZ",
