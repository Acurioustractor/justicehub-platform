          "children": [
            {
              "type": "text",
              "id": "BnChB",
              "x": 22,
              "y": 15,
              "fill": "#FFF7ED",
              "textGrowth": "fixed-width",
              "width": 226,
              "content": "CARD 01 / FOUNDERS",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 20,
              "fontWeight": "700"
            }
          ]
        },
        {
          "type": "text",
          "id": "lUwlk",
          "x": 56,
          "y": 150,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 820,
          "content": "Start with the people leading the work",
          "lineHeight": 0.96,
          "fontFamily": "Playfair Display",
          "fontSize": 74,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "9zK7f",
          "x": 56,
          "y": 316,
          "fill": "#7B6D61",
          "textGrowth": "fixed-width",
          "width": 820,
          "content": "Kristy Bloomfield and Tanya Turner, Oonchiumpa",
          "lineHeight": 1.2,
          "fontFamily": "IBM Plex Mono",
          "fontSize": 24,
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "xzoq1",
          "x": 56,
          "y": 380,
          "fill": "#4F463F",
          "textGrowth": "fixed-width",
          "width": 792,
          "content": "Oonchiumpa is a 100% Aboriginal community-controlled organisation working across Central Australia. The trip should begin with the people holding cultural authority, family connection, and responsibility to act for their own young people.\n\nThis card sets the frame: community-led practice first, then the wider evidence and route system around it.",
          "lineHeight": 1.22,
          "fontFamily": "Inter",
          "fontSize": 34,
          "fontWeight": "500"
        },
        {
          "type": "frame",
          "id": "3em7Q",
          "x": 56,
          "y": 710,
          "width": 792,
          "height": 190,
          "fill": "#1A1A1A",
          "cornerRadius": 28,
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "a4Pio",
              "x": 28,
              "y": 26,
              "fill": "#DC2626",
              "textGrowth": "fixed-width",
              "width": 736,
              "content": "WHY THIS CARD COMES FIRST",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "nsBXF",
              "x": 28,
              "y": 66,
              "fill": "#F5F0E8",
              "textGrowth": "fixed-width",
              "width": 736,
              "content": "Before the statistics, before CivicScope, before the search, judges should meet the people leading the work.",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 30,
              "fontWeight": "600"
            }
          ]
        },
        {
          "type": "frame",
          "id": "OJvQk",
          "x": 956,
          "y": 56,
          "width": 468,
          "height": 938,
          "fill": "#F6E2DD",
          "cornerRadius": 28,
          "stroke": {
            "thickness": 2,
            "fill": "#E4B8AD"
          },
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "NgnpV",
              "x": 36,
              "y": 34,
              "fill": "#9F1D1D",
              "textGrowth": "fixed-width",
              "width": 396,
              "content": "SCAN TO OPEN",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "frame",
              "id": "STCFJ",
              "x": 104,
              "y": 86,
              "width": 260,
              "height": 260,
              "fill": {
                "type": "image",
