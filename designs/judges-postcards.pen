              "width": 736,
              "content": "NEXT MOVES",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "jdKf8",
              "x": 28,
              "y": 62,
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": 736,
              "content": "1. Return to the judges field guide\n2. Open the Oonchiumpa basecamp profile\n3. Read the longer Oonchiumpa story\n4. Use CivicScope to track the system story\n5. Search alternatives near your own court",
              "lineHeight": 1.22,
              "fontFamily": "Inter",
              "fontSize": 26,
