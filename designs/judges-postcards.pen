        },
        {
          "type": "frame",
          "id": "lsuMz",
          "x": 96,
          "y": 56,
          "width": 260,
          "height": 58,
          "fill": "#1E5E4B",
          "cornerRadius": 999,
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "HukhB",
              "x": 22,
              "y": 18,
              "fill": "#F5F0E8",
              "textGrowth": "fixed-width",
              "width": 176,
              "content": "CARD 06 / XAVIER",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 18,
              "fontWeight": "700"
            }
          ]
        },
        {
          "type": "text",
          "id": "3Tu49",
          "x": 96,
          "y": 150,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 740,
          "content": "What happens when one organisation does not give up",
          "lineHeight": 0.96,
          "fontFamily": "Playfair Display",
          "fontSize": 56,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "5Z2QL",
          "x": 96,
          "y": 316,
          "fill": "#4F463F",
          "textGrowth": "fixed-width",
          "width": 710,
          "content": "Xavier was one of Oonchiumpa's first clients. Other service providers did not share his disabilities and distanced from him when the relationship got hard. Oonchiumpa did not.\n\nFred Campbell says \"He trusts us. We earned that trust.\" Xavier was released from youth detention at the start of the year and has not been back in trouble. He helped build Stretch Beds from recycled plastic, bought his first pair of shoes with his pay, and ran home to show his family. Fred says he is quite capable of building on his own and sharing that with other kids.",
          "lineHeight": 1.24,
          "fontFamily": "Inter",
          "fontSize": 22,
          "fontWeight": "500"
        },
        {
          "type": "frame",
          "id": "MK59h",
          "x": 96,
          "y": 720,
          "width": 710,
          "height": 240,
          "fill": "#F0F8F3",
          "cornerRadius": 28,
          "stroke": {
            "thickness": 2,
            "fill": "#B7DACA"
          },
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "ceswk",
              "x": 28,
              "y": 22,
              "fill": "#1E5E4B",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "TAKE THIS BACK TO CHAMBERS",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "jdKf8",
              "x": 28,
              "y": 62,
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "1. Watch the Oonchiumpa video\n2. Find programs near your own court\n3. Share this page with colleagues\n4. Explore the CONTAINED campaign\n5. Stay connected to Oonchiumpa\n6. Support community-based alternatives",
              "lineHeight": 1.3,
              "fontFamily": "Inter",
              "fontSize": 20,
              "fontWeight": "600"
            }
          ]
        },
