              "content": "CARD 01 / FOUNDERS",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 18,
              "fontWeight": "700"
            }
          ]
        },
        {
          "type": "text",
          "id": "lUwlk",
          "x": 96,
          "y": 150,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 740,
          "content": "Start with the people leading the work",
          "lineHeight": 0.96,
          "fontFamily": "Playfair Display",
          "fontSize": 68,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "9zK7f",
          "x": 96,
          "y": 316,
          "fill": "#7B6D61",
          "textGrowth": "fixed-width",
          "width": 740,
          "content": "Kristy Bloomfield + Tanya Turner, Oonchiumpa leaders",
          "lineHeight": 1.2,
          "fontFamily": "IBM Plex Mono",
          "fontSize": 24,
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "xzoq1",
          "x": 96,
          "y": 380,
          "fill": "#4F463F",
          "textGrowth": "fixed-width",
          "width": 710,
          "content": "Kristy is a Central Arrernte, Eastern Arrernte and Alyawarra Traditional Owner. Her grandfather was Stolen Generations, taken to the Bungalow in Alice Springs. He married her grandmother in a church to stop police taking his own children.\n\nTanya is an Eastern Arrernte woman who graduated from UWA law school, worked as an associate at the Supreme Court of Victoria, and came home. Together they built Oonchiumpa from cultural authority first, legal knowledge second.",
          "lineHeight": 1.26,
          "fontFamily": "Inter",
          "fontSize": 24,
          "fontWeight": "500"
        },
        {
          "type": "frame",
          "id": "3em7Q",
          "x": 96,
          "y": 740,
          "width": 710,
          "height": 170,
          "fill": "#1A1A1A",
          "cornerRadius": 28,
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "a4Pio",
              "x": 28,
              "y": 26,
              "fill": "#DC2626",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "WHAT JUDGES SHOULD KNOW",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "nsBXF",
              "x": 28,
              "y": 66,
              "fill": "#F5F0E8",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "\"Aboriginal culturally led programs is working and has worked. The government should let it be.\" - Kristy",
              "lineHeight": 1.24,
              "fontFamily": "Inter",
              "fontSize": 24,
              "fontWeight": "600"
            }
          ]
        },
        {
          "type": "frame",
