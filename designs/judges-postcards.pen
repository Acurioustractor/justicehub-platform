    {
      "type": "frame",
      "id": "NKMtb",
      "x": 632,
      "y": 5097,
      "name": "Postcard 01 / Founders",
      "width": 1480,
      "height": 1050,
      "fill": "#0A0A0A",
      "cornerRadius": 44,
      "stroke": {
        "thickness": 2,
        "fill": "#2D2D2D"
      },
      "layout": "none",
      "children": [
        {
          "type": "frame",
          "id": "GOD7z",
          "x": 0,
          "y": 0,
          "name": "heroF",
          "clip": true,
          "width": 1480,
          "height": 1050,
          "fill": {
            "type": "image",
            "enabled": true,
            "url": "assets/oonchiumpa-founders-new.jpg",
            "mode": "fill"
          },
          "cornerRadius": 44
        },
        {
          "type": "rectangle",
          "id": "jWFvv",
          "x": 0,
          "y": 0,
          "name": "gradF",
          "fill": {
            "type": "gradient",
            "gradientType": "linear",
            "enabled": true,
            "rotation": 180,
            "size": {
              "height": 1
            },
            "colors": [
              {
