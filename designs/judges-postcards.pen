        {
          "type": "frame",
          "id": "jouWc",
          "x": 96,
          "y": 56,
          "width": 300,
          "height": 58,
          "fill": "#174C3F",
          "cornerRadius": 999,
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "HJwRS",
              "x": 22,
              "y": 18,
              "fill": "#F5F0E8",
              "textGrowth": "fixed-width",
              "width": 216,
              "content": "CARD 03 / JACKQUANN",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 18,
              "fontWeight": "700"
            }
          ]
        },
        {
          "type": "text",
          "id": "J3qfC",
          "x": 96,
          "y": 140,
          "fill": "#1A1A1A",
          "textGrowth": "fixed-width",
          "width": 740,
          "content": "Jackquann did not ask for harsher punishment",
          "lineHeight": 0.96,
          "fontFamily": "Playfair Display",
          "fontSize": 58,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "HHinz",
          "x": 96,
          "y": 310,
          "fill": "#7B6D61",
          "textGrowth": "fixed-width",
          "width": 740,
          "content": "Jackquann, 14, lives at Upper Camp with his grandfather",
          "lineHeight": 1.2,
          "fontFamily": "IBM Plex Mono",
          "fontSize": 20,
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "ix15p",
          "x": 96,
          "y": 350,
          "fill": "#4F463F",
          "textGrowth": "fixed-width",
          "width": 710,
          "content": "Jackquann lives at Upper Camp with his grandfather. He is 14. He has been in the Alice Springs Detention Centre. He described it plainly: \"At six o'clock you get locked down. You wait till tomorrow.\"\n\nAsked what would stop him getting in trouble, he said \"Looking after my family.\" Asked what he would tell politicians, he said \"Programs.\" He wants a job. He wants to start his own family.",
          "lineHeight": 1.26,
          "fontFamily": "Inter",
          "fontSize": 24,
          "fontWeight": "500"
        },
        {
          "type": "frame",
          "id": "YAcrv",
          "x": 96,
          "y": 740,
          "width": 710,
          "height": 210,
          "fill": "#1A1A1A",
          "cornerRadius": 28,
          "layout": "none",
          "children": [
            {
              "type": "text",
              "id": "VApBV",
              "x": 28,
              "y": 26,
              "fill": "#1BB283",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "WHAT JUDGES SHOULD HEAR",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "NY44f",
              "x": 28,
              "y": 66,
              "fill": "#F5F0E8",
              "textGrowth": "fixed-width",
              "width": 654,
              "content": "Family, programs, and practical support are what he named. Not punishment. Not compliance. Not deterrence.",
              "lineHeight": 1.24,
              "fontFamily": "Inter",
              "fontSize": 24,
              "fontWeight": "600"
            }
          ]
        },
        {
          "type": "frame",
          "id": "1XqGO",
