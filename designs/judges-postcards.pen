              "y": 26,
              "fill": "#1E5E4B",
              "textGrowth": "fixed-width",
              "width": 736,
              "content": "Keep this route close when the conversation turns to what culturally grounded legal leadership actually looks like in community.",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 30,
              "fontWeight": "600"
            }
          ]
        },
