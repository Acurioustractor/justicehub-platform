            },
            {
              "type": "text",
              "id": "T7qO1",
              "x": 36,
              "y": 384,
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": 396,
              "content": "Judges field guide",
              "lineHeight": 0.98,
              "fontFamily": "Playfair Display",
              "fontSize": 52,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "OHbRu",
              "x": 36,
              "y": 490,
              "fill": "#7B6D61",
              "textGrowth": "fixed-width",
              "width": 396,
              "content": "justicehub.com.au/judges-on-country",
              "lineHeight": 1.2,
              "fontFamily": "IBM Plex Mono",
              "fontSize": 22,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "ENHi9",
              "x": 36,
              "y": 572,
              "fill": "#4F463F",
              "textGrowth": "fixed-width",
              "width": 396,
              "content": "Open the trip route, video, local search, and follow-through prompts.",
              "lineHeight": 1.22,
              "fontFamily": "Inter",
              "fontSize": 30,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "wm5EE",
              "x": 36,
              "y": 760,
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": 396,
              "content": "Use this card to frame the visit as an encounter with community-led authority rather than an inspection of a program.",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 28,
              "fontWeight": "600"
            }
          ]
        },
        {
