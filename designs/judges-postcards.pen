              "y": 34,
              "fill": "#7A3424",
              "textGrowth": "fixed-width",
              "width": 728,
              "content": "Take this card into CivicScope to trace what governments say about youth justice, what oversight has already recommended, and where removal from family is still being normalised.",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 30,
              "fontWeight": "600"
            }
